{
    "name": "discord-bot-template",
    "type": "module",
    "private": true,
    "scripts": {
        "postinstall": "bunx lefthook install && NODE_ENV=setup bun run scripts/createEnv.ts",
        "start": "NODE_ENV=production bun run src/index.ts",
        "dev": "NODE_ENV=development bun run src/index.ts",
        "register": "NODE_ENV=register bun run scripts/registerCommand.ts",
        "generate": "drizzle-kit generate",
        "generate:local": "drizzle-kit generate --config=drizzle-dev.config.ts",
        "migrate": "drizzle-kit migrate",
        "migrate:local": "NODE_ENV=development bun run scripts/migrate.ts",
        "db:seed:local": "NODE_ENV=development bun run scripts/seedLocalDb.ts",
        "db:reset:local": "NODE_ENV=development bun run scripts/resetLocalDb.ts",
        "studio": "drizzle-kit studio",
        "studio:local": "drizzle-kit studio --config=drizzle-dev.config.ts",
        "generateERdiagram": "bun run scripts/generateERdiagram.ts",
        "clean": "bun run scripts/clean.ts",
        "test": "bun test",
        "lint": "bunx @biomejs/biome lint --write",
        "lint:no-save": "bunx @biomejs/biome lint",
        "format": "bunx @biomejs/biome format --write",
        "format:no-save": "bunx @biomejs/biome format",
        "check": "bunx @biomejs/biome check --write",
        "check:no-save": "bunx @biomejs/biome check",
        "check:tsc": "bunx tsc --noEmit"
    },
    "dependencies": {
        "@electric-sql/pglite": "0.4.5",
        "discord.js": "14.26.4",
        "drizzle-orm": "1.0.0-rc.1",
        "postgres": "3.4.9",
        "zod": "4.4.3"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.14",
        "@types/bun": "latest",
        "drizzle-kit": "1.0.0-rc.1",
        "lefthook": "2.1.6",
        "typescript": "6.0.3"
    },
    "trustedDependencies": [
        "@biomejs/biome",
        "esbuild"
    ],
    "packageManager": "bun@1.3.11"
}
